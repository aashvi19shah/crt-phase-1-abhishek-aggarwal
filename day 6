//call by value is photocooy
//call by reference is original copy(address)

#include<iostream>
using namespace std;

void updatebyvalue(int a){
    a=500;
}

void updatebyreference(int&a){
    a=500;
}

int main(){
    int original = 100;
    cout<<original<<"\n";
    
    updatebyvalue(original);
    cout<<original<<"\n";
    updatebyreference(original);
    cout<<original;
}


